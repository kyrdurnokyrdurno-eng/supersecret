	end)
end)

local hitboxSize = 13
local hitboxTransparency = 0.8
local hitboxColor = Color3.fromRGB(0, 170, 255)
local hitboxExpanded = false
local hitboxHighlighted = false
local hitboxVisible = true
local savedHitboxes = {}

local colorOptions = {
	Blue = Color3.fromRGB(0, 170, 255),
	Green = Color3.fromRGB(70, 255, 95),
	Red = Color3.fromRGB(255, 55, 75),
	Orange = Color3.fromRGB(255, 125, 25),
	Yellow = Color3.fromRGB(255, 235, 45),
	White = Color3.fromRGB(255, 255, 255)
}

local function getEnemyRoot(otherPlayer)
	if otherPlayer == Players.LocalPlayer then
		return nil
	end

	local character = otherPlayer.Character
	if not character then
		return nil
	end

	return character:FindFirstChild("HumanoidRootPart")
end

local function removeHitboxHighlight(hrp)
	for _, item in ipairs(hrp:GetChildren()) do
		if item:IsA("Highlight") and item.Name == "OPSlapHitboxHighlight" then
			item:Destroy()
		end
	end
end

local function applyHitboxToPlayer(otherPlayer)
	local hrp = getEnemyRoot(otherPlayer)
	if not hrp then
		return
	end

	if not savedHitboxes[otherPlayer] then
		savedHitboxes[otherPlayer] = {
			Size = hrp.Size,
			Transparency = hrp.Transparency,
			Color = hrp.Color,
			CanCollide = hrp.CanCollide
		}
	end

	hrp.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
	hrp.Transparency = hitboxVisible and hitboxTransparency or 1
	hrp.Color = hitboxColor
	hrp.CanCollide = false

	removeHitboxHighlight(hrp)

	if hitboxHighlighted then
		local highlight = Instance.new("Highlight")
		highlight.Name = "OPSlapHitboxHighlight"
		highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
		highlight.FillColor = hitboxColor
		highlight.FillTransparency = 0.55
		highlight.OutlineTransparency = 0
		highlight.Parent = hrp
	end
end

local function resetHitboxForPlayer(otherPlayer)
	local hrp = getEnemyRoot(otherPlayer)
	local saved = savedHitboxes[otherPlayer]

	if hrp and saved then
		hrp.Size = saved.Size
		hrp.Transparency = saved.Transparency
		hrp.Color = saved.Color
		hrp.CanCollide = saved.CanCollide
		removeHitboxHighlight(hrp)
	end

	savedHitboxes[otherPlayer] = nil
end

local function refreshHitboxes()
	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if hitboxExpanded then
			applyHitboxToPlayer(otherPlayer)
		else
			resetHitboxForPlayer(otherPlayer)
		end
	end
end

