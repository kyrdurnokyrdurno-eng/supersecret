local function createCombatSlider(titleText, minValue, maxValue, step, defaultValue, callback)
	local holder = Instance.new("Frame")
	holder.Size = UDim2.new(1, -6, 0, 72)
	holder.BorderSizePixel = 0
	holder.Parent = combatList
	themeObject(holder, "BackgroundColor3", "ButtonDark")
	addCorner(holder, 8)
	addStroke(holder, Color3.fromRGB(0, 0, 0), 2)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -20, 0, 28)
	label.Position = UDim2.fromOffset(10, 4)
	label.BackgroundTransparency = 1
	label.Text = titleText .. ": " .. tostring(defaultValue)
	label.Font = Enum.Font.GothamBold
	label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Center
	label.Parent = holder
	themeObject(label, "TextColor3", "Text")

	local minus = Instance.new("TextButton")
	minus.Size = UDim2.fromOffset(42, 30)
	minus.Position = UDim2.fromOffset(10, 36)
	minus.Text = "-"
	minus.Font = Enum.Font.GothamBold
	minus.TextSize = 18
	minus.Parent = holder
	themeObject(minus, "BackgroundColor3", "Button")
	styleButton(minus)

	local plus = Instance.new("TextButton")
	plus.Size = UDim2.fromOffset(42, 30)
	plus.Position = UDim2.new(1, -52, 0, 36)
	plus.Text = "+"
	plus.Font = Enum.Font.GothamBold
	plus.TextSize = 18
	plus.Parent = holder
	themeObject(plus, "BackgroundColor3", "Button")
	styleButton(plus)

	local value = defaultValue

	local function setValue(newValue)
		value = math.clamp(newValue, minValue, maxValue)
		value = math.floor((value / step) + 0.5) * step
		value = math.round(value * 10) / 10
		label.Text = titleText .. ": " .. tostring(value)
		callback(value)
	end

	minus.MouseButton1Click:Connect(function()
		setValue(value - step)
	end)

	plus.MouseButton1Click:Connect(function()
		setValue(value + step)
	end)

	updateCombatCanvas()
	return holder
end

